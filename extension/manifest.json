{
    "manifest_version": 3,
    "name": "OpenNIT Vault",
    "version": "2.4.1",
    "description": "OpenNIT Vault – Passwort-Manager mit Autofill für Benutzer-, Passwort- und 2FA-Felder direkt im Browser.",
    "permissions": [
        "storage",
        "activeTab",
        "scripting",
        "alarms",
        "offscreen",
        "identity"
    ],
    "host_permissions": [
        "<all_urls>"
    ],
    "background": {
        "service_worker": "background.js"
    },
    "action": {
        "default_popup": "popup.html",
        "default_title": "OpenNIT Vault",
        "default_icon": {
            "16": "icon16.png",
            "32": "icon32.png"
        }
    },
    "content_scripts": [
        {
            "matches": [
                "<all_urls>"
            ],
            "js": [
                "content.js"
            ],
            "run_at": "document_idle"
        }
    ],
    "options_ui": {
        "page": "options.html",
        "open_in_tab": true
    },
    "icons": {
        "16": "icon16.png",
        "48": "icon48.png",
        "128": "icon128.png"
    }
}